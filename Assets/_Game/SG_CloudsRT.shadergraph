{
    "m_SGVersion": 1,
    "m_Type": "UnityEditor.ShaderGraph.CustomFunctionNode",
    "m_ObjectId": "1b561d4373e94e089a8f5918cda19ca4",
    "m_Group": {
        "m_Id": ""
    },
    "m_Name": "HistogramScan_float (Custom Function)",
    "m_DrawState": {
        "m_Expanded": true,
        "m_Position": {
            "serializedVersion": "2",
            "x": 1063.0,
            "y": 492.0,
            "width": 272.0,
            "height": 165.99993896484376
        }
    },
    "m_Slots": [
        {
            "m_Id": "3515f9630f924407a79604b59ea919c7"
        },
        {
            "m_Id": "dc123f84bfbe4be1b91c14a19743b9cf"
        },
        {
            "m_Id": "8fa4055d734d4a08be3ec903c2561461"
        },
        {
            "m_Id": "77a417bf4d06410d86dc22b5a1282499"
        },
        {
            "m_Id": "bdb0cccf72f94bb497ab92f2e66a54ba"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": false,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 1,
    "m_FunctionName": "HistogramScan_float",
    "m_FunctionSource": "",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "// Prevent division by zero when Contrast is exactly 1\r\n    float contrastRange = max(0.0001, 1.0 - Contrast);\r\n\r\n    // Calculate the midpoint. Substance maps Position 0 to black (midpoint 1) and 1 to white (midpoint 0)\r\n    float center = 1.0 - Position;\r\n\r\n    // Calculate the lower bound of our linear remap\r\n    float minVal = center - (contrastRange * 0.5);\r\n\r\n    // Inverse Lerp (Linear Remap) and clamp the result between 0 and 1\r\n    float result = saturate((In - minVal) / contrastRange);\r\n\r\n    // Apply the Invert toggle\r\n    Out = Invert ? 1.0 - result : result;"
}

